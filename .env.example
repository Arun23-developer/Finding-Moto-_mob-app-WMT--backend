# Server Configuration
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/finding-moto

# Seeded admin account

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP
# Leave SMTP_HOST empty to use Gmail service mode with SMTP_USER + SMTP_PASS.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=Finding Moto
